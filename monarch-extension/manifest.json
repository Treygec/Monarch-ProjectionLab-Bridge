{
  "manifest_version": 3,
  "name": "Monarch \u2192 ProjectionLab Bridge",
  "version": "2.0.0",
  "description": "Sync Monarch Money account balances to ProjectionLab using the Plugin API.",
  "permissions": [
    "storage",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost/*",
    "https://app.projectionlab.com/*",
    "https://us-central1-monarch-bridge-prod.cloudfunctions.net/*",
    "https://identitytoolkit.googleapis.com/*",
    "https://securetoken.googleapis.com/*",
    "https://api.monarch.com/*"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Monarch \u2192 ProjectionLab Bridge",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}